{
  "routes": [
    { "src": "/login", "dest": "/login.php" },
    { "src": "/dashboard", "dest": "/dashboard.php" },
    { "src": "/scan", "dest": "/scan.php" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/", "dest": "/login.php" }
  ]
}
